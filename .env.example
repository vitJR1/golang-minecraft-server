# Copy to `.env` and edit as needed. Values are read at startup by
# logger.Init() / main.loadEnv(); changes take effect on next restart.
#
# All variables are optional — defaults make the server work out of the box.

# --- Listener ----------------------------------------------------------------

# TCP port the server binds to. Default: 25565 (vanilla Minecraft port).
PORT=25565

# --- Logger ------------------------------------------------------------------

# Minimum log level: debug | info | warn | error. Default: info.
#   debug  — every packet noise, handshake transitions, status pings
#   info   — lifecycle (connections, joins, chat, commands)
#   warn   — recoverable failures (mojang auth, keep-alive timeouts)
#   error  — panics, write/read errors
LOG_LEVEL=info

# Log output format: text | json. Default: text.
#   text — human-readable, key=value
#   json — line-delimited JSON, for Loki / Vector / Promtail
LOG_FORMAT=text

# --- Authentication ----------------------------------------------------------

# Online mode forces the client to authenticate against Mojang's session
# server. Default: false (offline mode — anyone can connect with any name).
# Enable for public servers where you care about account ownership.
ONLINE_MODE=false

# Hard cap on simultaneous players. Shown in the server-list ping AND
# enforced at login (N+1th non-op connection gets "Server is full").
# Ops bypass the cap. Set 0 for unlimited. Default: 20.
MAX_PLAYERS=20

# --- Combat -----------------------------------------------------------------

# PvP combat model new instances start with:
#   1 = 1.8  — no attack cooldown, every hit deals full weapon damage.
#   2 = 1.9  — attack-cooldown "charge" scaling (a fresh swing is weak).
# The hub is always a safe zone regardless. Per-instance PvP can be toggled
# live with /instance set pvp on|off. Default: 2.
PVP_VERSION=2

# --- PostgreSQL --------------------------------------------------------------

# Set false to skip connecting (server boots without it). Default: true.
POSTGRES_ENABLED=true

# Either set a full DSN (overrides the discrete vars below)…
# DATABASE_URL=postgres://minecraft:minecraft@localhost:5432/minecraft?sslmode=disable
# …or use the discrete settings. Defaults match docker-compose.yml.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=minecraft
POSTGRES_PASSWORD=minecraft
POSTGRES_DB=minecraft
POSTGRES_SSLMODE=disable
# Max pooled connections. 0 (or unset) lets pgx pick its default (4× CPUs).
POSTGRES_MAX_CONNS=0

# --- Redis -------------------------------------------------------------------

# Set false to skip connecting (server boots without it). Default: true.
REDIS_ENABLED=true

# Either a full URL (overrides the discrete vars)…
# REDIS_URL=redis://localhost:6379/0
# …or the discrete settings. Defaults match docker-compose.yml.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Auth plugin ------------------------------------------------------------

# Toggle the auth module (/register, /login, dedicated auth instance,
# IP ban after repeated failures). When unset, the default depends on
# ONLINE_MODE: ON for offline servers (you need passwords because Mojang
# can't vouch for names), OFF for online servers. Explicitly set true /
# false here to override.
AUTH_ENABLED=true

# How long a connecting player has to /register or /login before being
# kicked. time.ParseDuration format: 30s, 5m, 1h, 1h30m. Default: 30s.
AUTH_TIMEOUT=30s

# Consecutive wrong-password attempts on the same IP that trigger an
# automatic IP ban. Default: 3.
AUTH_MAX_ATTEMPTS=3

# How long a banned IP stays blocked. Default: 1h.
AUTH_BAN_DURATION=1h

# --- Operators ---------------------------------------------------------------

# Comma-separated player names granted op on startup. They can immediately
# use /op /gamemode /tp /ban /kick /mute /instance /template. Names are
# matched case-insensitively.
# Default: the names baked into cfg.InitialOps.
INITIAL_OPS=_LD5Coffee_,LD5Coffee
